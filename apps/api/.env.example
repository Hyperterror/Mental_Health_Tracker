# ============================================================
# MindfulPrep — Backend Environment Variables
# Copy to apps/api/.env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ── Database (Supabase PostgreSQL) ──────────────────────────
# Pooled connection (used by Prisma at runtime)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (used by Prisma for migrations)
DIRECT_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── JWT Secrets (generate with: openssl rand -hex 64) ───────
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here_replace_this
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here_replace_this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Upstash Redis ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ── Google Gemini AI ─────────────────────────────────────────
GEMINI_API_KEY=your-google-ai-api-key-here

# ── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
